---
import type { HTMLAttributes } from "astro/types";
import { getImage } from "../lib/images/imageDataHelper";
import { IMAGE_SOURCES, type ImageMetadataRuntimeSchema } from "../lib/images/constsAndTypes";

interface Props extends HTMLAttributes<"img"> {
    name?: ImageName;
    data?: ImageMetadataRuntimeSchema;
    noPlaceholder?: boolean;
    autoWidth?: boolean;
}

const { name, data, noPlaceholder = false, autoWidth = false, ...props } = Astro.props;

let image = data;
if (!image && name) {
    image = getImage(name);
}

if (image) {
    props.src ??= image.path;
    props.alt ??= image.alt;

    const style = props.style
        ? (props.style as string).split(";").reduce(
              (prev, curr) => {
                  const [key, value] = curr.split(":").map((str) => str.trim());
                  prev[key] = value;
                  return prev;
              },
              {} as Record<string, string>,
          )
        : {};

    if (!noPlaceholder) {
        style["background-color"] ??= image.color;
        style["background-image"] ??= `url("${image.placeholderUri}")`;
        style["background-position"] ??= "center";
        style["background-size"] ??= "cover";

        // unset background on load, to avoid background behind transparent images
        props.onload ??= "this.style.backgroundColor=\"unset\";this.style.backgroundImage=\"unset\";";
    }

    if (autoWidth) {
        style["width"] ??= "auto";
    }

    style["aspect-ratio"] ??= image.ratio.toFixed(5);

    props.style = Object.keys(style)
        .reduce(
            (styleString, prop) =>
                styleString + prop + ": " + style[prop] + "; ",
            "",
        )
        .trimEnd();

    const classList = [props["class:list"], props.class?.split(" ")];

    if (image.source == IMAGE_SOURCES.STATIC_INTAKE) {
        classList.unshift("px");
    }

    props["class:list"] = classList;
    props.class = undefined;
}

props.draggable ??= "false";
---

<img {...props} />
