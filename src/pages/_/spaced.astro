---
import BaseMetadata from "../../components/head/base-metadata.astro";
import GlobalStylesLoader from "../../components/head/global-styles-loader.astro";
import PageMetadata from "../../components/head/page-metadata.astro";
import Image from "../../components/image.astro";
import Noise from "../../components/noise.astro";
import { getAllImages, getImagesByTag } from "../../lib/images/imageDataHelper";

const images = getImagesByTag("site-lingermyth"); //getAllImages();
---

<!doctype html>
<html lang="en">
    <head>
        <BaseMetadata />
        <GlobalStylesLoader />
        <PageMetadata
            title={`${"GRID"} (on Duncan’s Website)`}
            desc="Yes, that’s right! This is his website! He is a London-based photographer, writer, and web developer from Milwaukee, Wisconsin. Come inside. Take off your coat. Stay a while."
        />
    </head>
    <body>
        <Noise />
        <nav>
            <span>
                <a href="/" title="back! to the home page">Home</a>
                /
                <h1>
                    <a
                        href={"/galleries/spaced"}
                        title={"spaced gallery" + " (you're already here!)"}
                        >All Images</a
                    >
                </h1>
            </span>
            <span>
                <a href="#info" title="Information">Text</a>
            </span>
        </nav>
        <main>
            {
                images.map((image) => {
                    const widthPX = Math.random() * 200 + 200;
                    const leftLERP = Math.random();
                    const topPX = Math.random() * 200 + 200;
                    return (
                        <figure style={`--widthPX: ${widthPX}px; --leftLerp: ${leftLERP}; --topPX: ${topPX}px; --ratio-sqrt: ${Math.sqrt(image.ratio).toFixed(5)};`}>
                            <Image data={image} />
                        </figure>
                    );
                })
            }
        </main>
    </body>
</html>

<style>
    main {
        padding: calc(var(--padding) / 3) calc(var(--padding) / 2);
        overflow: hidden;
    }

    figure {
        position: relative;
        z-index: 2;

        --widthPX: 400px;
        --leftLerp: 0;
        --topPX: 300px;
        --ratio-sqrt: 1;
        
        --actual-width: calc(var(--widthPX) * var(--ratio-sqrt));

        width: min(var(--widthPX), 100%);
        margin-left: calc((100% - var(--widthPX)) * var(--leftLerp));
        margin-top: var(--topPX);

        cursor: zoom-in;

        opacity: 1;
        transform: none;
        filter: none;

        transition:
            box-shadow 0.5s,
            opacity 0.5s,
            transform 0.5s,
            filter 1s;
    }

    figure.off-screen {
        opacity: 0;
        transform: translate(10px, 20px) rotate(2deg);
        filter: blur(10px);
    }

    figure:hover {
        box-shadow: 0 0 12px var(--color-bg-dark);
        transform: scale(1.004);
    }

    body:has(figure:hover) figure:not(:hover) {
        filter: blur(1px);
    }

    body:has(figure) nav {
        transition:
            filter 1s,
            opacity 0.5s;
    }

    body:has(figure:hover) nav {
        filter: blur(2px);
        opacity: 0.8;
    }

    nav {
        position: fixed;
        z-index: 1;
        padding: calc(var(--padding) / 3) calc(var(--padding) / 2);

        width: 100%;
        display: flex;
        justify-content: space-between;

        user-select: none;
        -webkit-user-select: none;
        pointer-events: none;

        font-variant-numeric: lining-nums;
        font-variation-settings:
            "wght" 600,
            "wdth" 100,
            "ENLA" 20;

        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;

        @media screen and (max-width: 58ch) {
            flex-direction: column;
        }

        h1 {
            font-size: unset;
            display: inline;
            margin: 0;
        }

        a {
            color: unset;
            text-decoration: none;
            pointer-events: auto;
            user-select: auto;
            -webkit-user-select: auto;
        }

        a:hover,
        a:focus-visible {
            text-decoration: underline;
            text-decoration-thickness: 0.0875em;
            text-underline-offset: 0.125em;
        }

        a:focus-visible,
        a:active {
            outline: none;
            background-color: var(--color-primary);
            color: var(--color-bg);
        }
    }
</style>

<script>
    function initGallery() {
        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach((entry) => {
                const show =
                    entry.isIntersecting || entry.boundingClientRect.top <= 0;
                entry.target.classList.toggle("off-screen", !show);
            });
        });

        document.querySelectorAll("figure").forEach((_f) => {
            const figure = _f as HTMLElement;
            observer.observe(figure);
        });
    }

    document.addEventListener("DOMContentLoaded", initGallery);
</script>
